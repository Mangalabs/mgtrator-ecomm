# =============================================
# MG Trator Peças - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# =============================================

# --------------------------------------------
# Gestaoclick API (obrigatório)
# --------------------------------------------
CLICK_API_URL=https://api.gestaoclick.com/api
CLICK_API_ACCESS_TOKEN=seu_access_token_aqui
CLICK_API_PRIVATE_TOKEN=seu_private_token_aqui
CLICK_API_STORE_ID=

# Aliases alternativos (opcional, mesma função)
# GESTAOCLICK_BASE_URL=https://api.gestaoclick.com
# GESTAOCLICK_ACCESS_TOKEN=
# GESTAOCLICK_SECRET_TOKEN=
# GESTAOCLICK_REVALIDATE_SECONDS=60
# GESTAOCLICK_LOJA_ID=

# --------------------------------------------
# Backend de estoque (opcional)
# Preencha se tiver um backend próprio
# --------------------------------------------
# MGTRATOR_BACKEND_URL=https://api.mgtrator.com
# ECOM_BACKEND_URL=
# INVENTORY_BACKEND_URL=

# --------------------------------------------
# Site
# --------------------------------------------
NEXT_PUBLIC_SITE_URL=https://mgtratorpecas.com.br
